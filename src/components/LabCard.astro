---
interface Props {
  title: string;
  summary: string;
  date: string;
  tags: string[];
  slug: string;
  headingLevel?: 'h2' | 'h3';
}

const { title, summary, date, tags, slug, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;
---

<a
  href={`/lab/${slug}/`}
  class="group relative flex flex-col bg-bg-secondary border border-border rounded-card p-5 transition-colors duration-150 hover:border-accent overflow-hidden"
>
  <div class="absolute top-0 left-0 right-0 h-0.5 bg-accent opacity-0 transition-opacity duration-150 group-hover:opacity-100" aria-hidden="true"></div>
  <Heading class="font-sans text-card-title font-semibold text-text-primary">{title}</Heading>
  {summary && <p class="mt-2 text-sm text-text-secondary leading-relaxed">{summary}</p>}
  <div class="mt-auto pt-3 flex items-center justify-between gap-3">
    <div class="flex gap-2 flex-wrap">
      {tags.map((tag) => (
        <span class="font-mono text-badge uppercase tracking-wide bg-accent/10 text-accent px-1.5 py-0.5 rounded">{tag}</span>
      ))}
    </div>
    <time class="font-mono text-xs text-text-muted shrink-0" datetime={date}>
      {date}
    </time>
  </div>
</a>
