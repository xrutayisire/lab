---
interface Props {
  text: string;
  linkText?: string;
  linkUrl?: string;
}

const { text, linkText, linkUrl } = Astro.props;
---

<aside
  role="note"
  class="mb-8 rounded-card border border-border bg-bg-secondary p-4 font-mono text-sm text-text-secondary"
>
  <div class="flex gap-3">
    <span class="shrink-0 text-accent" aria-hidden="true">&gt;</span>
    <p>
      {text}
      {linkText && linkUrl && (
        <>
          {' '}
          <a
            href={linkUrl}
            class="text-accent hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            {linkText} &rarr;
          </a>
        </>
      )}
    </p>
  </div>
</aside>
