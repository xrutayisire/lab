---
const year = new Date().getFullYear();

const links = [
  {
    label: 'linkedin',
    href: 'https://www.linkedin.com/in/xavierrutayisire/',
    ariaLabel: 'LinkedIn profile',
    icon: 'linkedin',
  },
  {
    label: 'github',
    href: 'https://github.com/xrutayisire',
    ariaLabel: 'GitHub profile',
    icon: 'github',
  },
  {
    label: 'source',
    href: 'https://github.com/xrutayisire/lab',
    ariaLabel: 'View source code',
    icon: 'code',
  },
  {
    label: 'rss',
    href: '/rss.xml',
    ariaLabel: 'RSS feed',
    icon: 'rss',
  },
];
---

<footer class="w-full max-w-content mx-auto px-6 max-md:px-4 py-8 border-t border-border flex items-center justify-between max-md:flex-col max-md:gap-3">
  <p class="font-mono text-xs text-text-muted">&copy; {year} Xavier Rutayisire</p>
  <nav aria-label="Social links" class="flex items-center gap-4">
    {links.map((link) => (
      <a
        href={link.href}
        {...(link.href.startsWith('/') ? {} : { target: '_blank', rel: 'noopener noreferrer' })}
        class="flex items-center gap-1.5 font-mono text-xs text-text-muted transition-colors duration-150 hover:text-accent"
        aria-label={link.ariaLabel}
      >
        {link.icon === 'linkedin' && (
          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/>
          </svg>
        )}
        {link.icon === 'github' && (
          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
        )}
        {link.icon === 'code' && (
          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M4.708 5.578L2.061 8.224l2.647 2.646-.708.708L.293 7.87a.5.5 0 010-.708L4 3.454l.708.708zm6.584 0l2.647 2.646-2.647 2.646.708.708L15.707 7.87a.5.5 0 000-.708L12 3.454l-.708.708zM6.932 13.085l-1.165-.39 3.3-9.79 1.166.39-3.3 9.79z"/>
          </svg>
        )}
        {link.icon === 'rss' && (
          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2zm1.5 12a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm0-5.5a5 5 0 0 1 5 5h-1.5a3.5 3.5 0 0 0-3.5-3.5V5zm0-3a8 8 0 0 1 8 8h-1.5A6.5 6.5 0 0 0 3.5 5V3.5z"/>
          </svg>
        )}
        {link.label}
      </a>
    ))}
  </nav>
</footer>
