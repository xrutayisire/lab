---
import Base from '../layouts/Base.astro';
---

<Base title="About — Xavier Rutayisire" description="Staff engineer at Prismic. Building software for ten years, using AI every day to ship better products.">
  <h1 class="font-sans text-page-title max-md:text-2xl font-semibold text-text-primary mb-8">About</h1>
  <div class="text-base text-text-primary leading-prose space-y-5">
    <p>
      I'm Xavier. I've been building software for ten years and I'm currently a staff engineer
      at <a href="https://prismic.io" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Prismic</a>,
      where I build products, lead a team, and use AI every day to do better work.
    </p>
    <p>
      I built this site to share what I learn along the way — what works, what doesn't,
      and the decisions behind it. Field notes are short posts about things I've tried or built.
      The lab is a collection of tools I maintain and keep working.
    </p>
    <p>
      Everything here comes from my actual work.
    </p>
  </div>
  <div class="mt-8 flex items-center gap-4 max-md:flex-col max-md:items-start max-md:gap-2">
    <a
      href="https://github.com/xrutayisire"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-1.5 font-mono text-sm text-text-muted transition-colors duration-150 hover:text-accent"
    >
      <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
      </svg>
      github
    </a>
    <a
      href="https://www.linkedin.com/in/xavierrutayisire/"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-1.5 font-mono text-sm text-text-muted transition-colors duration-150 hover:text-accent"
    >
      <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/>
      </svg>
      linkedin
    </a>
  </div>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Xavier Rutayisire',
    url: 'https://xrutayisire.dev',
    jobTitle: 'Staff Software Engineer',
    sameAs: [
      'https://github.com/xrutayisire',
      'https://www.linkedin.com/in/xavierrutayisire/',
    ],
  })} />
</Base>
