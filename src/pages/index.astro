---
import Base from '../layouts/Base.astro';
import FieldNoteCard from '../components/FieldNoteCard.astro';
import LabCard from '../components/LabCard.astro';
import { getCollection } from 'astro:content';

const allFieldNotes = (await getCollection('field-notes'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allLabArtifacts = (await getCollection('lab')).sort((a, b) => {
  if (a.data.status === 'maintained' && b.data.status !== 'maintained') return -1;
  if (a.data.status !== 'maintained' && b.data.status === 'maintained') return 1;
  return b.data.lastUpdated.localeCompare(a.data.lastUpdated);
});

const fieldNotes = allFieldNotes.slice(0, 3);
const labArtifacts = allLabArtifacts.slice(0, 4);
const hasMoreNotes = allFieldNotes.length > 3;
const hasMoreLab = allLabArtifacts.length > 4;
---

<Base title="Xavier Rutayisire — Staff Engineer" description="Field notes and open-source tools from a staff engineer working at the intersection of software and AI.">
  <header class="text-center mb-12">
    <h1 class="font-sans text-hero max-md:text-3xl font-bold text-text-primary">Xavier Rutayisire</h1>
    <p class="mt-2 text-lg text-text-secondary">A staff engineer's notes on AI in production</p>
  </header>

  <section class="mb-12" aria-labelledby="field-notes-heading">
    <div class="flex items-center gap-4 mb-6">
      <h2 id="field-notes-heading" class="font-mono text-xs uppercase tracking-widest text-text-muted shrink-0">
        Field Notes
      </h2>
      <div class="h-px flex-1 bg-border" aria-hidden="true"></div>
    </div>
    <div class="flex flex-col gap-1">
      {fieldNotes.map((note) => (
        <FieldNoteCard
          title={note.data.title}
          date={note.data.date.toISOString().split('T')[0]}
          summary={note.data.summary}
          slug={note.id}
        />
      ))}
    </div>
    {hasMoreNotes && (
      <a href="/field-notes/" class="block mt-4 text-right font-mono text-xs text-text-muted transition-colors duration-150 hover:text-accent">
        all field notes &rarr;
      </a>
    )}
  </section>

  <section aria-labelledby="lab-heading">
    <div class="flex items-center gap-4 mb-6">
      <h2 id="lab-heading" class="font-mono text-xs uppercase tracking-widest text-text-muted shrink-0">
        Lab
      </h2>
      <div class="h-px flex-1 bg-border" aria-hidden="true"></div>
    </div>
    <div class="grid grid-cols-2 max-md:grid-cols-1 gap-3">
      {labArtifacts.map((artifact) => (
        <LabCard
          name={artifact.data.name}
          description={artifact.data.description}
          status={artifact.data.status}
          lastUpdated={artifact.data.lastUpdated}
          topics={artifact.data.topics}
          slug={artifact.id}
        />
      ))}
    </div>
    {hasMoreLab && (
      <a href="/lab/" class="block mt-4 text-right font-mono text-xs text-text-muted transition-colors duration-150 hover:text-accent">
        all lab projects &rarr;
      </a>
    )}
  </section>
</Base>
