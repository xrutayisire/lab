---
import Base from '../layouts/Base.astro';
import FieldNoteCard from '../components/FieldNoteCard.astro';
import LabCard from '../components/LabCard.astro';
import { getCollection } from 'astro:content';

const allFieldNotes = (await getCollection('field-notes'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allLabProjects = (await getCollection('lab'))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fieldNotes = allFieldNotes.slice(0, 3);
const labProjects = allLabProjects.slice(0, 4);
const hasMoreNotes = allFieldNotes.length > 3;
const hasMoreLab = allLabProjects.length > 4;
---

<Base title="Xavier Rutayisire — Staff Engineer" description="Field notes, open-source projects, and experiments from a staff engineer working at the intersection of software and AI.">
  <header class="text-center mb-12">
    <h1 class="font-sans text-hero max-md:text-3xl font-bold text-text-primary">Xavier Rutayisire</h1>
    <p class="mt-2 text-lg text-text-secondary cursor-blink">A staff engineer's notes on AI in production</p>
  </header>

  <section class="mb-12" aria-labelledby="field-notes-heading">
    <div class="flex items-center gap-4 mb-6">
      <h2 id="field-notes-heading" class="font-mono text-xs uppercase tracking-widest text-text-muted shrink-0">
        Field Notes
      </h2>
      <div class="h-px flex-1 bg-border" aria-hidden="true"></div>
    </div>
    <div class="flex flex-col gap-1">
      {fieldNotes.map((note) => (
        <FieldNoteCard
          title={note.data.title}
          date={note.data.date.toISOString().split('T')[0]}
          summary={note.data.summary}
          tags={note.data.tags}
          slug={note.id}
        />
      ))}
    </div>
    {hasMoreNotes && (
      <a href="/field-notes/" class="block mt-4 text-right font-mono text-xs text-text-muted transition-colors duration-150 hover:text-accent">
        all field notes &rarr;
      </a>
    )}
  </section>

  <section aria-labelledby="lab-heading">
    <div class="flex items-center gap-4 mb-6">
      <h2 id="lab-heading" class="font-mono text-xs uppercase tracking-widest text-text-muted shrink-0">
        Lab
      </h2>
      <div class="h-px flex-1 bg-border" aria-hidden="true"></div>
    </div>
    <div class="grid grid-cols-2 max-md:grid-cols-1 gap-3">
      {labProjects.map((project) => (
        <LabCard
          title={project.data.title}
          summary={project.data.summary}
          date={project.data.date.toISOString().split('T')[0]}
          tags={project.data.tags}
          slug={project.id}
        />
      ))}
    </div>
    {hasMoreLab && (
      <a href="/lab/" class="block mt-4 text-right font-mono text-xs text-text-muted transition-colors duration-150 hover:text-accent">
        all lab projects &rarr;
      </a>
    )}
  </section>
</Base>
