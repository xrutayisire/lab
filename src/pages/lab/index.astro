---
import Base from '../../layouts/Base.astro';
import LabCard from '../../components/LabCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('lab'))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Lab — Xavier Rutayisire" description="Open-source projects, experiments, and things I've tried — by Xavier Rutayisire.">
  <h1 class="font-sans text-page-title max-md:text-2xl font-semibold text-text-primary mb-8">Lab</h1>
  {projects.length > 0 ? (
    <div class="grid grid-cols-2 max-md:grid-cols-1 gap-3">
      {projects.map((project) => (
        <LabCard
          title={project.data.title}
          summary={project.data.summary}
          date={project.data.date.toISOString().split('T')[0]}
          tags={project.data.tags}
          slug={project.id}
          headingLevel="h2"
        />
      ))}
    </div>
  ) : (
    <p class="text-text-secondary">No lab projects yet. Check back soon.</p>
  )}
</Base>
