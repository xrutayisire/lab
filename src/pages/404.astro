---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Xavier Rutayisire" description="Page not found.">
  <h1 class="sr-only">Page not found</h1>
  <div class="flex flex-col items-center justify-center text-center min-h-center">
    <div class="font-mono text-sm text-text-muted bg-bg-secondary border border-border rounded-card p-8 max-w-md w-full text-left">
      <p class="text-text-secondary">
        <span class="text-accent">visitor@xrutayisire.dev</span>:<span class="text-text-muted">~</span>$
        cd {Astro.url.pathname}
      </p>
      <p class="mt-2 text-text-primary">
        bash: cd: {Astro.url.pathname}: No such file or directory
      </p>
      <p class="mt-4 text-text-secondary">
        <span class="text-accent">visitor@xrutayisire.dev</span>:<span class="text-text-muted">~</span>$
        cat /var/log/suggestions.txt
      </p>
      <p class="mt-2 text-text-primary">
        Looks like this page doesn't exist. Maybe try one of these:
      </p>
      <ul class="mt-3 space-y-1">
        <li><a href="/" class="text-accent hover:underline">~/home</a> — start here</li>
        <li><a href="/field-notes/" class="text-accent hover:underline">~/field-notes</a> — what I'm learning</li>
        <li><a href="/lab/" class="text-accent hover:underline">~/lab</a> — what I'm building</li>
        <li><a href="/about/" class="text-accent hover:underline">~/about</a> — who I am</li>
      </ul>
      <p class="mt-4 text-text-secondary">
        <span class="text-accent">visitor@xrutayisire.dev</span>:<span class="text-text-muted">~</span>$
        <span class="inline-block w-2 h-4 bg-accent animate-pulse align-middle" aria-hidden="true"></span>
      </p>
    </div>
  </div>
</Base>
