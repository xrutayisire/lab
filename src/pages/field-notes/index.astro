---
import Base from '../../layouts/Base.astro';
import FieldNoteCard from '../../components/FieldNoteCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('field-notes'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Field Notes — Xavier Rutayisire" description="Notes from the intersection of staff engineering and AI.">
  <h1 class="font-sans text-page-title max-md:text-2xl font-semibold text-text-primary mb-8">Field Notes</h1>
  {posts.length > 0 ? (
    <div class="flex flex-col gap-1">
      {posts.map((post) => (
        <FieldNoteCard
          title={post.data.title}
          date={post.data.date.toISOString().split('T')[0]}
          summary={post.data.summary}
          slug={post.id}
          headingLevel="h2"
        />
      ))}
    </div>
  ) : (
    <p class="text-text-secondary">No field notes yet. Check back soon.</p>
  )}
</Base>
